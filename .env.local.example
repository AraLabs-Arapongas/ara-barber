# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Hosts
# APP_BASE_HOST: domínio raiz. Tenants vivem em <slug>.aralabs.com.br.
# Admin (platform) mora em repo separado (aralabs storefront), fora deste app.
NEXT_PUBLIC_APP_BASE_HOST=aralabs.com.br
NEXT_PUBLIC_DEV_BASE_HOST=lvh.me

# Env marker (development | preview | production)
NEXT_PUBLIC_ENV=development
